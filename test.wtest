import resolucion.*

const  armando = new Permanente(
  nombre = "Armando",
  sueldoBasico = 1000,
  direccion = "Calle Falsa 123",
  estadoCivil = true,
  fechaNac = new Date(day = 30, month = 6, year = 1973),
  cantHijos = 3,
  antiguedad = 10,
  salario = 0
)

const  lucia = new Temporario(
  nombre = "Lucia",
  sueldoBasico = 6000,
  direccion = "Calle Verdadera 456",
  estadoCivil = false,
  salario = 0,
  fechaNac = new Date(day = 15, month = 4, year = 1989),
    horasExtra = 20,
  fechaDesign = new Date(day = 1, month = 1, year = 2010)
)

const maconas = new Empresa(
  nombre = "Maconas",
  cuit = 30123456789,
  empleados = [armando, lucia],
  recibosDeHaberes = []
)

describe "Testeo de Empleado Permanente"{
   test "Sueldo Neto"{
        assert.equals(armando.sueldoNeto(), 1477.5)
    }
    test "Sueldo Bruto"{
        assert.equals(armando.sueldoBruto(), 2050)
    }
    test "Retenciones"{
        assert.equals(armando.retenciones(), 572.5)
    }
}

// mal hecho, revisar
describe "Testeo de Empleado Temporario"{
   test "Sueldo Neto"{
        assert.equals(lucia.sueldoNeto(), 6900)
    }
    test "Sueldo Bruto"{
        assert.equals(lucia.sueldoBruto(), 7000)
    }
    test "Retenciones"{
        assert.equals(lucia.retenciones(), 100)
    }
}

describe "Testeo de Empresa"{

    test "Sueldo Total Neto"{
        assert.equals(maconas.montoTotalSueldosNeto(), 8950)
    }
    test "Sueldo Total Bruto"{
        assert.equals(maconas.montoTotalSueldosBruto(), 9050)
    }
    test "Retenciones Totales"{
        assert.equals(maconas.montoTotalRetenciones(), 672.5)
    }
}